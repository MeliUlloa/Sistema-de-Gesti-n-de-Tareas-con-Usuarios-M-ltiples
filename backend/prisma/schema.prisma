generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role

  tasks     TaskUser[]

  createdAt DateTime  @default(now())
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  status      TaskStatus @default(pending)
  priority    Priority

  users       TaskUser[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model TaskUser {
  id        Int @id @default(autoincrement())

  userId    Int
  taskId    Int

  confirmed Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
  task Task @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId])
}

enum Role {
  admin
  user
}

enum TaskStatus {
  pending
  in_progress
  completed
}

enum Priority {
  low
  medium
  high
}